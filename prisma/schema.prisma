generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String?  @unique
  phone        String?  @unique
  passwordHash String?
  name         String
  role         String   @default("CUSTOMER")
  avatarUrl    String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  customerProfile CustomerProfile?
  employeeProfile EmployeeProfile?
  orders          Order[]            @relation("CustomerOrders")
  assignedOrders  Order[]            @relation("AssignedOrders")
  stageJobs       ProductionStage[]  @relation("StageAssignee")
  tickets         SupportTicket[]
  quotes          Quote[]
  addresses       Address[]
  wishlist        WishlistItem[]
  notifications   Notification[]
  auditLogs       AuditLog[]
  attendance      Attendance[]
  leaveRequests   LeaveRequest[]
  salarySlips     SalarySlip[]
  expensesCreated Expense[]          @relation("ExpenseCreator")
  crmNotes        CrmNote[]
  staffPayments   StaffPayment[]
}

model CustomerProfile {
  id            String  @id @default(cuid())
  userId        String  @unique
  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName   String?
  gstNumber     String?
  walletBalance Float   @default(0)
  rewardPoints  Int     @default(0)
}

model EmployeeProfile {
  id          String    @id @default(cuid())
  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  department  String?
  designation String?
  salary      Float     @default(0)
  joinDate    DateTime?
  pfNumber    String?
  esiNumber   String?
  bankName    String?
  bankAccount String?
  ifsc        String?
}

model Address {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  label     String  @default("Home")
  line1     String
  line2     String?
  city      String
  state     String
  pincode   String
  isDefault Boolean @default(false)
}

model SiteSettings {
  id              String  @id @default("main")
  businessName    String  @default("RENU PRESS")
  tagline         String  @default("Printing & Branding Solutions")
  experienceYears Int     @default(12)
  phone           String  @default("+91 76314 25111")
  whatsapp        String  @default("917631425111")
  email           String  @default("hello@renupress.in")
  address         String  @default("Near Bus Stand, Saharsa, Bihar 852201")
  city            String  @default("Saharsa")
  state           String  @default("Bihar")
  pincode         String  @default("852201")
  gst             String  @default("10XXXXX1234X1Z5")
  businessHours   String  @default("Mon-Sat: 9:00 AM - 8:00 PM | Sunday: Closed")
  mapsEmbedUrl    String  @default("https://maps.google.com/maps?q=Saharsa+Bihar&output=embed")
  mapsLink        String  @default("https://maps.google.com/?q=Saharsa,+Bihar")
  facebook        String  @default("")
  instagram       String  @default("")
  youtube         String  @default("")
  linkedin        String  @default("")
  heroTitle       String  @default("Print that carries your name with pride.")
  heroSubtitle    String  @default("From wedding cards to corporate branding — RENU PRESS delivers precision printing across Saharsa and Bihar.")
  aboutTitle      String  @default("Crafted in Saharsa. Trusted across Bihar.")
  aboutBody       String  @default("RENU PRESS is a full-service printing and branding house based in Saharsa. We combine traditional press craft with modern digital production — serving shops, schools, offices, political campaigns, and families who need work that looks finished.")
  storyBody       String  @default("What started as a neighbourhood press has grown into a complete production floor: offset, digital, outdoor media, apparel, gifts, and signage. Our team still proof-reads every invitation and checks every colour before it leaves the shop.")
  seoTitle        String  @default("RENU PRESS | Printing & Branding Solutions in Saharsa, Bihar")
  seoDescription  String  @default("Offset, digital, flex, wedding cards, ID cards, corporate branding and more. RENU PRESS — Saharsa's complete printing partner.")
  gaId            String  @default("")
  popupEnabled    Boolean @default(false)
  popupTitle      String  @default("Need a quote today?")
  popupBody       String  @default("Send your size and quantity on WhatsApp — we reply during business hours.")
  maintenance     Boolean @default(false)
  updatedAt       DateTime @updatedAt
}

model ServiceCategory {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  sortOrder Int       @default(0)
  isActive  Boolean   @default(true)
  services  Service[]
}

model Service {
  id          String          @id @default(cuid())
  name        String
  slug        String          @unique
  description String
  categoryId  String
  category    ServiceCategory @relation(fields: [categoryId], references: [id])
  imageUrl    String?
  isFeatured  Boolean         @default(false)
  isActive    Boolean         @default(true)
  sortOrder   Int             @default(0)
  basePrice   Float?
  unit        String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  products    Product[]
}

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String
  serviceId   String?
  service     Service? @relation(fields: [serviceId], references: [id])
  sizes       String   @default("[]")
  materials   String   @default("[]")
  finishings  String   @default("[]")
  minQty      Int      @default(1)
  basePrice   Float    @default(0)
  isActive    Boolean  @default(true)
  imageUrl    String?
  createdAt   DateTime @default(now())
  orders      Order[]
  wishlist    WishlistItem[]
}

model PortfolioItem {
  id          String   @id @default(cuid())
  title       String
  client      String?
  category    String
  description String
  imageUrl    String
  beforeUrl   String?
  afterUrl    String?
  isFeatured  Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
}

model GalleryImage {
  id        String   @id @default(cuid())
  title     String
  imageUrl  String
  album     String   @default("General")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  role      String?
  company   String?
  body      String
  rating    Int      @default(5)
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

model Faq {
  id        String  @id @default(cuid())
  question  String
  answer    String
  category  String  @default("General")
  sortOrder Int     @default(0)
  isActive  Boolean @default(true)
}

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String
  body        String
  coverUrl    String?
  published   Boolean  @default(false)
  seoTitle    String?
  seoDesc     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Page {
  id        String  @id @default(cuid())
  title     String
  slug      String  @unique
  body      String
  published Boolean @default(true)
  seoTitle  String?
  seoDesc   String?
}

model Slider {
  id        String  @id @default(cuid())
  title     String
  subtitle  String?
  imageUrl  String
  ctaLabel  String?
  ctaHref   String?
  sortOrder Int     @default(0)
  isActive  Boolean @default(true)
}

model ProcessStep {
  id        String @id @default(cuid())
  title     String
  body      String
  sortOrder Int    @default(0)
}

model WhyChoose {
  id        String @id @default(cuid())
  title     String
  body      String
  icon      String @default("check")
  sortOrder Int    @default(0)
}

model Industry {
  id        String @id @default(cuid())
  name      String
  body      String
  sortOrder Int    @default(0)
}

model Lead {
  id          String    @id @default(cuid())
  name        String
  phone       String
  email       String?
  service     String?
  message     String
  source      String    @default("website")
  status      String    @default("new")
  notes       String?
  urgency      String    @default("normal")
  leadScore    Int       @default(0)
  city         String?
  businessName String?
  summary      String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  crmNotes     CrmNote[]
  conversation SupportConversation?
}

/// Digital Support Desk — full conversation + ERP handover
model SupportConversation {
  id                   String   @id @default(cuid())
  sessionId            String   @unique
  customerName         String?
  phone                String?
  email                String?
  businessName         String?
  city                 String?
  deliveryAddress      String?
  product              String?
  size                 String?
  material             String?
  quantity             String?
  deadline             String?
  budget               String?
  remarks              String?
  /// NEW_INQUIRY | REQUIREMENT_COLLECTED | QUALIFIED | WAITING_REVIEW | QUOTE_PENDING | QUOTE_SENT | NEGOTIATION | CONFIRMED | PRODUCTION | COMPLETED | LOST
  status               String   @default("NEW_INQUIRY")
  urgency              String   @default("normal")
  leadScore            Int      @default(0)
  aiSummary            String?
  recommendedProducts  String?
  /// Customer intent label (e.g. clothing shop branding)
  customerIntent       String?
  interestedCategory   String?
  suggestedBundle      String?
  /// Full JSON recommendation payload for ERP / chat cards
  recommendationJson   String?
  /// JSON map of collected field keys
  collectedFields      String   @default("{}")
  language             String   @default("hinglish")
  nextField            String?  @default("product")
  leadId               String?  @unique
  lead                 Lead?    @relation(fields: [leadId], references: [id])
  notifiedAdmin        Boolean  @default(false)
  quotePrice           Float?
  quoteDelivery        String?
  quoteRemarks         String?
  quotePdfUrl          String?
  quoteStatus          String?
  adminNotifiedAt      DateTime?
  lastCustomerAt       DateTime?
  lastAgentAt          DateTime?
  theme                String   @default("dark")
  isOpen               Boolean  @default(true)
  messages             SupportMessage[]
  files                SupportFile[]
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model SupportMessage {
  id             String   @id @default(cuid())
  conversationId String
  conversation   SupportConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  /// customer | agent | system | admin
  role           String
  content        String
  /// text | image | file | voice | system
  messageType    String   @default("text")
  metadata       String?
  createdAt      DateTime @default(now())

  @@index([conversationId, createdAt])
}

model SupportFile {
  id             String   @id @default(cuid())
  conversationId String
  conversation   SupportConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  messageId      String?
  fileName       String
  mimeType       String
  sizeBytes      Int      @default(0)
  /// data URL or relative path (size-limited)
  storageData    String?
  analysis       String?
  ocrText        String?
  category       String?
  version        Int      @default(1)
  /// Print readiness score 0–100
  printScore     Int?
  printGrade     String?
  /// Link to latest ArtworkInspection
  inspectionId   String?
  deleted        Boolean  @default(false)
  createdAt      DateTime @default(now())
  inspections    ArtworkInspection[]

  @@index([conversationId])
}

/// Pre-press Artwork Quality Inspector — versioned reports (original never modified)
model ArtworkInspection {
  id               String   @id @default(cuid())
  supportFileId    String?
  supportFile      SupportFile? @relation(fields: [supportFileId], references: [id], onDelete: SetNull)
  conversationId   String?
  fileName         String
  mimeType         String
  sizeBytes        Int      @default(0)
  score            Int      @default(0)
  grade            String   @default("Average")
  category         String?
  maxPrintSize     String?
  colourMode       String?
  resolutionLevel  String?
  warnings         String?
  suggestions      String?
  suitableProducts String?
  /// Full PrintReadinessReport JSON
  reportJson       String
  /// Optional parent for revision history
  parentId         String?
  parent           ArtworkInspection?  @relation("InspectionRevisions", fields: [parentId], references: [id], onDelete: SetNull)
  revisions        ArtworkInspection[] @relation("InspectionRevisions")
  version          Int      @default(1)
  /// Requested optional fixes (JSON array of fix ids)
  requestedFixes   String?
  createdAt        DateTime @default(now())

  @@index([conversationId])
  @@index([score])
  @@index([createdAt])
}

model AdminAlert {
  id        String   @id @default(cuid())
  type      String   @default("SUPPORT_LEAD")
  title     String
  body      String
  meta      String?
  read      Boolean  @default(false)
  href      String?
  createdAt DateTime @default(now())
}

model Quote {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  name        String
  phone       String
  email       String?
  service     String
  size        String?
  material    String?
  quantity    Int      @default(1)
  finishing   String?
  notes       String?
  artworkUrl  String?
  estimate    Float?
  status      String   @default("requested")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Order {
  id              String        @id @default(cuid())
  orderNumber     String        @unique
  customerId      String
  customer        User          @relation("CustomerOrders", fields: [customerId], references: [id])
  assignedToId    String?
  assignedTo      User?         @relation("AssignedOrders", fields: [assignedToId], references: [id])
  productId       String?
  product         Product?      @relation(fields: [productId], references: [id])
  serviceName     String
  size            String?
  material        String?
  quantity        Int           @default(1)
  finishing       String?
  artworkUrl      String?
  notes           String?
  status String @default("PENDING")
  subtotal        Float         @default(0)
  tax             Float         @default(0)
  total           Float         @default(0)
  advancePaid     Float         @default(0)
  /// Phone on order for call / WhatsApp
  customerPhone   String?
  /// CASH | ONLINE | UPI | PARTIAL | CARD
  paymentMethod   String        @default("CASH")
  paidAmount      Float         @default(0)
  dueAmount       Float         @default(0)
  discount        Float         @default(0)
  /// FLAT | PERCENT
  discountType    String        @default("FLAT")
  gstPct          Float         @default(18)
  billNo          String?
  /// JSON string of line items [{name,qty,rate}]
  itemsJson       String?
  paymentStatus String @default("UNPAID")
  trackingCode    String?
  deliveryAddress String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  payments        Payment[]
  statusHistory   OrderStatusLog[]
  invoice         Invoice?
  stages          ProductionStage[]
}

model OrderStatusLog {
  id        String      @id @default(cuid())
  orderId   String
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status String
  note      String?
  createdAt DateTime    @default(now())
}

model Invoice {
  id            String   @id @default(cuid())
  invoiceNumber String   @unique
  orderId       String   @unique
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  amount        Float
  tax           Float    @default(0)
  total         Float
  issuedAt      DateTime @default(now())
  dueAt         DateTime?
  pdfUrl        String?
}

model Payment {
  id        String        @id @default(cuid())
  orderId   String
  order     Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  amount    Float
  method String
  reference String?
  status    String        @default("success")
  paidAt    DateTime      @default(now())
}

model SupportTicket {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  subject   String
  body      String
  status    String   @default("open")
  priority  String   @default("normal")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WishlistItem {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model InventoryItem {
  id           String   @id @default(cuid())
  name         String
  sku          String?  @unique
  barcode      String?
  category     String
  warehouse    String   @default("Main")
  unit         String   @default("pcs")
  quantity     Float    @default(0)
  reorderLevel Float    @default(10)
  unitCost     Float    @default(0)
  supplierId   String?
  supplier     Supplier? @relation(fields: [supplierId], references: [id])
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())
  adjustments  StockAdjustment[]
}

model StockAdjustment {
  id        String        @id @default(cuid())
  itemId    String
  item      InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  delta     Float
  reason    String
  createdAt DateTime      @default(now())
}

model Supplier {
  id          String          @id @default(cuid())
  name        String
  phone       String?
  email       String?
  gst         String?
  address     String?
  notes       String?
  /// What products they supply
  products    String?
  createdAt   DateTime        @default(now())
  items       InventoryItem[]
  purchases   PurchaseOrder[]
  expenses    Expense[]
  ledger      SupplierLedger[]
}

/// Supplier paid / purchase / due ledger
model SupplierLedger {
  id         String   @id @default(cuid())
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  /// PURCHASE | PAYMENT | ADJUST
  type       String
  amount     Float
  method     String   @default("CASH")
  note       String?
  createdAt  DateTime @default(now())
}

/// Staff mid-month advance / salary payment entries
model StaffPayment {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// ADVANCE | SALARY | BONUS
  type      String   @default("ADVANCE")
  amount    Float
  method    String   @default("CASH")
  note      String?
  paidAt    DateTime @default(now())
  createdAt DateTime @default(now())
}

model PurchaseOrder {
  id            String   @id @default(cuid())
  poNumber      String   @unique
  supplierId    String
  supplier      Supplier @relation(fields: [supplierId], references: [id])
  status        String   @default("DRAFT")
  total         Float    @default(0)
  notes         String?
  orderedAt     DateTime @default(now())
  receivedAt    DateTime?
  createdAt     DateTime @default(now())
}

model Expense {
  id            String   @id @default(cuid())
  title         String
  category      String
  amount        Float
  expenseDate   DateTime @default(now())
  vendorName    String?
  supplierId    String?
  supplier      Supplier? @relation(fields: [supplierId], references: [id])
  paymentMethod String   @default("CASH")
  bankName      String?
  upiRef        String?
  referenceNo   String?
  billNumber    String?
  gstAmount     Float    @default(0)
  gstNumber     String?
  status        String   @default("PAID")
  description   String?
  proofUrl      String?
  proofName     String?
  ocrRaw        String?
  createdById   String?
  createdBy     User?    @relation("ExpenseCreator", fields: [createdById], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model BankAccount {
  id        String   @id @default(cuid())
  name      String
  bankName  String
  accountNo String
  ifsc      String?
  balance   Float    @default(0)
  isActive  Boolean  @default(true)
}

model Attendance {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date       DateTime
  checkIn    DateTime?
  checkOut   DateTime?
  status     String   @default("PRESENT")
  lateMins   Int      @default(0)
  notes      String?
  lat        Float?
  lng        Float?
  createdAt  DateTime @default(now())

  @@unique([userId, date])
}

model LeaveRequest {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromDate  DateTime
  toDate    DateTime
  type      String   @default("CASUAL")
  reason    String
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
}

model SalarySlip {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  month       Int
  year        Int
  basic       Float
  overtime    Float    @default(0)
  bonus       Float    @default(0)
  advance     Float    @default(0)
  deduction   Float    @default(0)
  pf          Float    @default(0)
  esi         Float    @default(0)
  netSalary   Float
  status      String   @default("DRAFT")
  paidAt      DateTime?
  proofUrl    String?
  createdAt   DateTime @default(now())

  @@unique([userId, month, year])
}

model ProductionStage {
  id           String   @id @default(cuid())
  orderId      String
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  stage        String
  status       String   @default("PENDING")
  assigneeId   String?
  assignee     User?    @relation("StageAssignee", fields: [assigneeId], references: [id])
  startedAt    DateTime?
  completedAt  DateTime?
  notes        String?
  sortOrder    Int      @default(0)
}

model CrmNote {
  id        String   @id @default(cuid())
  leadId    String?
  lead      Lead?    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  type      String   @default("NOTE")
  body      String
  remindAt  DateTime?
  createdAt DateTime @default(now())
}

model DocumentVault {
  id        String   @id @default(cuid())
  title     String
  category  String
  fileUrl   String
  fileName  String?
  relatedTo String?
  createdAt DateTime @default(now())
}

/// Bill PNG for WhatsApp send (public image URL + optional Cloud API)
model BillImage {
  id           String   @id @default(cuid())
  billNo       String
  phone        String
  customerName String?
  total        Float?
  /// raw base64 without data: prefix
  dataBase64   String
  mimeType     String   @default("image/png")
  createdAt    DateTime @default(now())

  @@index([billNo])
  @@index([createdAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entity    String?
  meta      String?
  createdAt DateTime @default(now())
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model CareerJob {
  id          String   @id @default(cuid())
  title       String
  department  String
  location    String   @default("Saharsa, Bihar")
  type        String   @default("Full-time")
  description String
  isOpen      Boolean  @default(true)
  createdAt   DateTime @default(now())
}

/// Product / FAQ knowledge for retrieval (pgvector-ready; store embedding as JSON floats if extension off)
model KnowledgeChunk {
  id        String   @id @default(cuid())
  kind      String   @default("product")
  title     String
  content   String
  metadata  String?
  /// JSON array of floats — optional local embedding; use pgvector migration for native vector search
  embedding String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([kind])
}

